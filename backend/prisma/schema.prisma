// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id                Int                @id @default(autoincrement())
  email             String             @unique
  password          String
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  sessions          Session[]          @relation("ProfileSessions")
  verificationCodes VerificationCode[] @relation("ProfileCodes")
  apiKeys           ApiKey[]           @relation("ProfileApiKeys")
  feeds             Feed[]             @relation("ProfileFeeds")
  items             Item[]             @relation("ProfileItems")

  @@map("profiles")
}

model Session {
  id        Int       @id @default(autoincrement())
  scope     String
  userAgent String    @map("user_agent")
  expiredAt DateTime  @default(dbgenerated("(now() + '4 days'::interval)")) @map("expired_at") @db.Timestamptz(3)
  endedAt   DateTime? @map("ended_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  profile   Profile   @relation("ProfileSessions", fields: [profileId], references: [id], onDelete: Cascade)
  profileId Int       @map("profile_id")
  apiKeyId  Int?      @map("api_key_id")
  apiKey    ApiKey?   @relation("ApiKeySession")

  @@map("sessions")
}

enum CodeType {
  LOGIN
  LOGOUT_ALL
  PASSWORD_RESET
  DELETE_PROFILE
  CREATE_API_KEY
}

model VerificationCode {
  id        Int       @id @default(autoincrement())
  type      CodeType  @default(LOGIN)
  value     String
  userAgent String    @map("user_agent")
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  expiredAt DateTime  @default(dbgenerated("(now() + '08:00:00'::interval)")) @map("expired_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  profile   Profile?  @relation("ProfileCodes", fields: [profileId], references: [id], onDelete: SetNull)
  profileId Int?      @map("profile_id")

  @@map("verification_codes")
}

model ApiKey {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  value     String?
  origin    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  profile   Profile  @relation("ProfileApiKeys", fields: [profileId], references: [id], onDelete: Cascade)
  profileId Int      @map("profile_id")
  session   Session? @relation("ApiKeySession", fields: [sessionId], references: [id], onDelete: SetNull)
  sessionId Int?     @unique @map("session_id")

  @@map("api_keys")
}

model Feed {
  id         Int         @id @default(autoincrement())
  path       String      @unique
  profileId  Int         @map("profile_id")
  profile    Profile     @relation("ProfileFeeds", fields: [profileId], references: [id], onDelete: Cascade)
  components Component[] @relation("FeedComponents")

  @@map("feeds")
}

enum ComponentType {
  BASIC_BLOCK
}

model Component {
  id        Int           @id @default(autoincrement())
  type      ComponentType @default(BASIC_BLOCK)
  title     String?
  config    Json          @default("{}")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  feed      Feed          @relation("FeedComponents", fields: [feedId], references: [id], onDelete: Cascade)
  feedId    Int

  @@map("components")
}

model Item {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  sortName    String      @map("sort_name")
  isPrivate   Boolean     @default(true) @map("is_private")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)
  publishedAt DateTime?   @map("published_at") @db.Timestamptz(3)
  expiredAt   DateTime?   @map("expired_at") @db.Timestamptz(3)
  author      Profile?    @relation("ProfileItems", fields: [authorId], references: [id], onDelete: SetNull)
  authorId    Int?        @map("author_id")
  dateRanges  DateRange[] @relation("ItemDateRanges")
  tags        ItemTag[]
  images      ItemImage[]

  @@map("items")
}

model DateRange {
  id          Int      @id @default(autoincrement())
  description String?
  startAt     DateTime @map("start_at") @db.Timestamptz(3)
  endAt       DateTime @map("end_at") @db.Timestamptz(3)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  item        Item     @relation("ItemDateRanges", fields: [itemId], references: [id], onDelete: Cascade)
  itemId      Int

  @@map("date_ranges")
}

enum TagName {
  PERSON
  PLACE
  THING
  PAST
  PRESENT
  FUTURE
  RED
  BLUE
  GREEN
  FOO
  BAR
  BAZ
}

model Tag {
  id    Int       @id @default(autoincrement())
  name  TagName   @unique
  items ItemTag[]

  @@map("tags")
}

model ItemTag {
  item   Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId Int  @map("item_id")
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  Int  @map("tag_id")

  @@id([itemId, tagId])
  @@map("items_tags")
}

enum ImageType {
  LANDSCAPE
  PORTRAIT
  ICON
  OTHER
}

model Image {
  id        Int         @id @default(autoincrement())
  url       String      @unique
  alt       String?
  type      ImageType   @default(OTHER)
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)
  items     ItemImage[]

  @@map("images")
}

model ItemImage {
  item    Item  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId  Int   @map("item_id")
  image   Image @relation(fields: [imageId], references: [id], onDelete: Cascade)
  imageId Int   @map("image_id")

  @@id([itemId, imageId])
  @@map("items_images")
}
