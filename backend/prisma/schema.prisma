// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id                Int                @id @default(autoincrement())
  email             String             @unique
  password          String
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  sessions          Session[]          @relation("ProfileSessions")
  verificationCodes VerificationCode[] @relation("ProfileCodes")
  apiKeys           ApiKey[]           @relation("ProfileApiKeys")
  feeds             Feed[]             @relation("ProfileFeeds")
  items             Item[]             @relation("ProfileItems")

  @@map("profiles")
}

model Session {
  id        Int       @id @default(autoincrement())
  scope     String
  userAgent String    @map("user_agent")
  expiredAt DateTime  @default(dbgenerated("(now() + '4 days'::interval)")) @map("expired_at") @db.Timestamptz(6)
  endedAt   DateTime? @map("ended_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  profile   Profile   @relation("ProfileSessions", fields: [profileId], references: [id], onDelete: Cascade)
  profileId Int       @map("profile_id")

  @@map("sessions")
}

enum CodeType {
  LOGIN
  LOGOUT_ALL
  PASSWORD_RESET
  DELETE_PROFILE
  CREATE_API_KEY
}

model VerificationCode {
  id        Int       @id @default(autoincrement())
  type      CodeType  @default(LOGIN)
  value     String
  userAgent String    @map("user_agent")
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  expiredAt DateTime  @default(dbgenerated("(now() + '08:00:00'::interval)")) @map("expired_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  profile   Profile?  @relation("ProfileCodes", fields: [profileId], references: [id], onDelete: SetNull)
  profileId Int?      @map("profile_id")

  @@map("verification_codes")
}

model ApiKey {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  value     String?
  origin    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  profile   Profile  @relation("ProfileApiKeys", fields: [profileId], references: [id], onDelete: Cascade)
  profileId Int      @map("profile_id")

  @@map("api_keys")
}

enum SubjectType {
  SINGLE
  COLLECTION
}

model Feed {
  id          Int         @id @default(autoincrement())
  path        String
  // Use this field to determine how to interpret the "path" field. For example, if subject is SINGLE_ITEM, then path would be the item ID. If subject is COLLECTION, then path could be any arbitrary string that the user can use to identify the feed.
  subjectType SubjectType @default(COLLECTION) @map("subject_type")
  publishedAt DateTime?   @map("published_at") @db.Timestamptz(6)
  expiredAt   DateTime?   @map("expired_at") @db.Timestamptz(6)
  profileId   Int         @map("profile_id")
  profile     Profile     @relation("ProfileFeeds", fields: [profileId], references: [id], onDelete: Cascade)
  components  Component[] @relation("FeedComponents")

  @@unique([profileId, path, subjectType])
  @@map("feeds")
}

enum ItemBinding {
  BY_URL
  FILTERED_BY_TAG
  MANUAL_CURATED
}

model ComponentType {
  id             Int         @id @default(autoincrement())
  name           String      @unique
  itemBinding    ItemBinding @default(FILTERED_BY_TAG) @map("item_binding")
  propertySchema Json        @default("{}") // Use this field to store any additional settings for the component such as "grid columns": 3, or "show title": true, etc.
  components     Component[]

  @@map("component_types")
}

model Component {
  id                Int             @id @default(autoincrement())
  order             Int             @default(0)
  type              ComponentType   @relation(fields: [typeId], references: [id])
  typeId            Int             @map("component_type_id")
  propertyValues    Json            @default("{}") @map("property_values") // Use this field to store the actual values for the settings defined in the ComponentType's propertySchema. For example, if the ComponentType has a setting called "grid columns", then this field would store the value for that setting such as "3".
  collectionFilters ComponentTag[]
  curatedItems      ComponentItem[]
  feed              Feed            @relation("FeedComponents", fields: [feedId], references: [id], onDelete: Cascade)
  feedId            Int
  publishedAt       DateTime?       @map("published_at") @db.Timestamptz(6)
  expiredAt         DateTime?       @map("expired_at") @db.Timestamptz(6)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([feedId, order])
  @@map("components")
}

model ComponentTag {
  component   Component @relation(fields: [componentId], references: [id], onDelete: Cascade)
  componentId Int       @map("component_id")
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId       Int       @map("tag_id")

  @@id([componentId, tagId])
  @@map("components_tags")
}

model ComponentItem {
  component   Component @relation(fields: [componentId], references: [id], onDelete: Cascade)
  componentId Int       @map("component_id")
  item        Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId      Int       @map("item_id")
  order       Int?

  @@id([componentId, itemId])
  @@map("components_items")
}

model Item {
  id             Int             @id @default(autoincrement())
  name           String
  description    String?
  sortName       String          @map("sort_name")
  isPrivate      Boolean         @default(true) @map("is_private")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  publishedAt    DateTime?       @map("published_at") @db.Timestamptz(6)
  expiredAt      DateTime?       @map("expired_at") @db.Timestamptz(6)
  author         Profile?        @relation("ProfileItems", fields: [authorId], references: [id], onDelete: SetNull)
  authorId       Int?            @map("author_id")
  dateRanges     DateRange[]     @relation("ItemDateRanges")
  tags           ItemTag[]
  images         ItemImage[]
  componentItems ComponentItem[]

  @@map("items")
}

model DateRange {
  id          Int      @id @default(autoincrement())
  description String?
  startAt     DateTime @map("start_at") @db.Timestamptz(6)
  endAt       DateTime @map("end_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  item        Item     @relation("ItemDateRanges", fields: [itemId], references: [id], onDelete: Cascade)
  itemId      Int

  @@map("date_ranges")
}

model Tag {
  id         Int            @id @default(autoincrement())
  name       String         @unique
  items      ItemTag[]
  components ComponentTag[]

  @@map("tags")
}

model ItemTag {
  item   Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId Int  @map("item_id")
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  Int  @map("tag_id")

  @@id([itemId, tagId])
  @@map("items_tags")
}

enum ImageType {
  LANDSCAPE
  PORTRAIT
  ICON
  OTHER
}

model Image {
  id        Int         @id @default(autoincrement())
  url       String      @unique
  alt       String?
  type      ImageType   @default(OTHER)
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  items     ItemImage[]

  @@map("images")
}

model ItemImage {
  item    Item  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId  Int   @map("item_id")
  image   Image @relation(fields: [imageId], references: [id], onDelete: Cascade)
  imageId Int   @map("image_id")

  @@id([itemId, imageId])
  @@map("items_images")
}
